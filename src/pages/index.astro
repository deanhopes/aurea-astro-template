---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Vision from '@components/Vision.astro';
import Residences from '@components/Residences.astro';
import Lifestyle from '@components/Lifestyle.astro';
import Neighbourhood from '@components/Neighbourhood.astro';
import Enquiry from '@components/Enquiry.astro';
---

<BaseLayout title="Aurea Residences">
  <Hero />
  <Vision />
  <Residences />
  <Lifestyle />
  <Neighbourhood />
  <Enquiry />

  <script>
    import { initVisionScroll, destroyVisionScroll } from '@lib/vision-scroll';

    document.addEventListener('astro:page-load', initVisionScroll);
    document.addEventListener('astro:before-swap', destroyVisionScroll);
  </script>
</BaseLayout>

---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
---

<BaseLayout title="Aurea Residences">
  <Hero />

  <!-- Vision teaser -->
  <section class="section">
    <div class="content-narrow">
      <h2 class="text-section" data-reveal>
        Where light meets water
      </h2>
      <p class="text-body-muted content-text mt-md" data-reveal>
        A 62-storey residential tower designed around the bay. Morning light floods
        every residence. The architecture is quiet, the views are not.
      </p>
    </div>
  </section>

  <!-- Residences teaser -->
  <section class="section">
    <div class="content-narrow">
      <h2 class="text-section" data-reveal>
        Residences
      </h2>
      <p class="text-body-muted content-text mt-md" data-reveal>
        One to four bedrooms, each with a private terrace facing the bay.
        Floor-to-ceiling glass. Interiors by appointment.
      </p>
      <a href="/residences" class="link-underline mt-md" data-reveal>
        View Residences
      </a>
    </div>
  </section>

  <!-- Location teaser -->
  <section class="section">
    <div class="content-narrow">
      <h2 class="text-section" data-reveal>
        Edgewater
      </h2>
      <p class="text-body-muted content-text mt-md" data-reveal>
        Between the bay and the Design District. Margaret Pace Park at your door.
        Wynwood around the corner. The neighbourhood that feels like Miami without
        performing it.
      </p>
      <a href="/location" class="link-underline mt-md" data-reveal>
        Explore Location
      </a>
    </div>
  </section>
</BaseLayout>

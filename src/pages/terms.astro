---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Terms & Conditions">
  <section class="section section--center">
    <div class="content-text">
      <p class="eyebrow">Legal</p>
      <h1 class="text-section-heading mt-sm">Terms &amp; Conditions</h1>
      <p class="text-body-muted mt-md">
        Placeholder. Replace with your terms before going live. A template scaffolded by Aurea —
        swap this file's contents with your own legal copy.
      </p>
      <a href="/" class="link-underline mt-md">Return home</a>
    </div>
  </section>
</BaseLayout>

<style>
  .eyebrow {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.75rem;
    line-height: 1.11;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-black) 50%, transparent);
  }
  .section--center .content-text {
    text-align: left;
  }
</style>

---
/**
 * /dev/footer — isolated footer shader testbed.
 * No BaseLayout, no nav, no scroll machinery — just the footer at full viewport height.
 * Tweakpane panel wired to all tunable shader uniforms.
 */
import Footer from '@components/Footer.astro';
import '@styles/fonts.css';
import '@styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Footer — dev</title>
    <style>
      /* Minimal reset — BaseLayout normally sets these */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html,
      body {
        width: 100%;
        height: 100%;
        overflow: hidden; /* footer fills viewport, no scroll needed */
        background: var(--color-background);
      }

      /* Make the footer fill the full viewport on this dev page */
      .site-footer {
        position: relative !important;
        margin-bottom: 0 !important;
        height: 100dvh !important;
        z-index: 0 !important;
      }

      /* body bg would cover z-index:-1 footer — remove it */
      html,
      body {
        background: transparent !important;
      }

      /* Tweakpane panel — top-right, above footer content */
      #tp-root {
        position: fixed;
        top: 16px;
        right: 16px;
        z-index: 9999;
      }
    </style>
  </head>
  <body>
    <!-- Scroll trigger stub — progress driven by tweakpane slider instead -->
    <div data-footer-trigger aria-hidden="true" style="display:none"></div>

    <Footer />

    <div id="tp-root"></div>

    <script>
      import { Pane, type FolderApi } from 'tweakpane';
      import {
        initFooterShaders,
        setProgress,
        uCausticScale,
        uCausticSpeed,
        uCausticSharpness,
        uCausticHeight,
        uShadowThreshold,
        uShadowSoftness,
        uShadowAlpha,
        uRefraction,
        uSpecStrength,
        uSpecSharp,
      } from '@lib/footer-shaders';

      await initFooterShaders({ staticProgress: 1 });

      const pane: FolderApi = new Pane({ container: document.getElementById('tp-root')! });

      const caustics = pane.addFolder({ title: 'Caustics', expanded: true });

      const cState = {
        scale: uCausticScale.value,
        speed: uCausticSpeed.value,
        sharpness: uCausticSharpness.value,
        height: uCausticHeight.value,
        progress: 1,
      };

      caustics
        .addBinding(cState, 'scale', { min: 1, max: 20, step: 0.1, label: 'Scale' })
        .on('change', ({ value }) => {
          uCausticScale.value = value;
        });

      caustics
        .addBinding(cState, 'speed', { min: 0, max: 0.5, step: 0.005, label: 'Speed' })
        .on('change', ({ value }) => {
          uCausticSpeed.value = value;
        });

      caustics
        .addBinding(cState, 'sharpness', { min: 0.5, max: 6, step: 0.1, label: 'Sharpness' })
        .on('change', ({ value }) => {
          uCausticSharpness.value = value;
        });

      caustics
        .addBinding(cState, 'height', { min: 0, max: 6, step: 0.1, label: 'Height' })
        .on('change', ({ value }) => {
          uCausticHeight.value = value;
        });

      caustics
        .addBinding(cState, 'progress', { min: 0, max: 1, step: 0.01, label: 'Progress' })
        .on('change', ({ value }) => {
          setProgress(value);
        });

      const shadows = pane.addFolder({ title: 'Shadow Mask', expanded: false });

      const sState = {
        threshold: uShadowThreshold.value,
        softness: uShadowSoftness.value,
        alpha: uShadowAlpha.value,
      };

      shadows
        .addBinding(sState, 'threshold', { min: -1, max: 1, step: 0.01, label: 'Threshold' })
        .on('change', ({ value }) => {
          uShadowThreshold.value = value;
        });

      shadows
        .addBinding(sState, 'softness', { min: 0, max: 4, step: 0.01, label: 'Softness' })
        .on('change', ({ value }) => {
          uShadowSoftness.value = value;
        });

      shadows
        .addBinding(sState, 'alpha', { min: 0, max: 1, step: 0.01, label: 'Opacity' })
        .on('change', ({ value }) => {
          uShadowAlpha.value = value;
        });

      const lighting = pane.addFolder({ title: 'Lighting', expanded: false });

      const lState = {
        refraction: uRefraction.value,
        specStrength: uSpecStrength.value,
        specSharp: uSpecSharp.value,
      };

      lighting
        .addBinding(lState, 'refraction', { min: 0, max: 0.1, step: 0.001, label: 'Refraction' })
        .on('change', ({ value }) => {
          uRefraction.value = value;
        });

      lighting
        .addBinding(lState, 'specStrength', { min: 0, max: 4, step: 0.01, label: 'Spec Strength' })
        .on('change', ({ value }) => {
          uSpecStrength.value = value;
        });

      lighting
        .addBinding(lState, 'specSharp', { min: 8, max: 256, step: 1, label: 'Spec Sharpness' })
        .on('change', ({ value }) => {
          uSpecSharp.value = value;
        });
    </script>
  </body>
</html>

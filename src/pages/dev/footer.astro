---
/**
 * /dev/footer — isolated footer shader testbed.
 * No BaseLayout, no nav, no scroll machinery — just the footer at full viewport height.
 * Tweakpane panel wired to all tunable shader uniforms.
 */
import Footer from '@components/Footer.astro';
import '@styles/fonts.css';
import '@styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Footer — dev</title>
    <style>
      /* Minimal reset — BaseLayout normally sets these */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html, body {
        width: 100%;
        height: 100%;
        overflow: hidden; /* footer fills viewport, no scroll needed */
        background: var(--color-background);
      }

      /* Make the footer fill the full viewport on this dev page */
      .site-footer {
        position: relative !important;
        margin-bottom: 0 !important;
        height: 100dvh !important;
        z-index: 0 !important;
      }

      /* body bg would cover z-index:-1 footer — remove it */
      html, body {
        background: transparent !important;
      }

      /* Tweakpane panel — top-right, above footer content */
      #tp-root {
        position: fixed;
        top: 16px;
        right: 16px;
        z-index: 9999;
      }
    </style>
  </head>
  <body>
    <!-- Scroll trigger stub — progress driven by tweakpane slider instead -->
    <div data-footer-trigger aria-hidden="true" style="display:none"></div>

    <Footer />

    <div id="tp-root"></div>

    <script>
      import { Pane } from 'tweakpane';
      import {
        initFooterShaders,
        setProgress,
        uCausticScale,
        uCausticSpeed,
        uCausticPower,
        uCausticBrightness,
        uMouseInfluence,
        uCausticWarp,
        uGradientWidth,
        uShadowThreshold,
        uShadowSoftness,
        uShadowAlpha,
      } from '@lib/footer-shaders';

      // Boot shaders at full reveal — staticProgress bypasses ScrollTrigger entirely
      await initFooterShaders({ staticProgress: 1 });

      const pane = new Pane({ container: document.getElementById('tp-root')! });

      // ── Caustics ────────────────────────────────────────────
      const caustics = pane.addFolder({ title: 'Caustics', expanded: true });

      const cState = {
        scale: uCausticScale.value as number,
        speed: uCausticSpeed.value as number,
        power: uCausticPower.value as number,
        brightness: uCausticBrightness.value as number,
        mouseInfluence: uMouseInfluence.value as number,
        warp: uCausticWarp.value as number,
        progress: 1,
      };

      caustics.addBinding(cState, 'scale', { min: 1, max: 20, step: 0.1, label: 'Scale' })
        .on('change', ({ value }) => { uCausticScale.value = value; });

      caustics.addBinding(cState, 'speed', { min: 0, max: 0.5, step: 0.005, label: 'Speed' })
        .on('change', ({ value }) => { uCausticSpeed.value = value; });

      caustics.addBinding(cState, 'power', { min: 0.5, max: 6, step: 0.1, label: 'Sharpness' })
        .on('change', ({ value }) => { uCausticPower.value = value; });

      caustics.addBinding(cState, 'brightness', { min: 0, max: 1, step: 0.01, label: 'Brightness' })
        .on('change', ({ value }) => { uCausticBrightness.value = value; });

      caustics.addBinding(cState, 'mouseInfluence', { min: 0, max: 0.2, step: 0.005, label: 'Mouse Shift' })
        .on('change', ({ value }) => { uMouseInfluence.value = value; });

      caustics.addBinding(cState, 'warp', { min: 0, max: 1, step: 0.01, label: 'Warp' })
        .on('change', ({ value }) => { uCausticWarp.value = value; });

      caustics.addBinding(cState, 'progress', { min: 0, max: 1, step: 0.01, label: 'Progress' })
        .on('change', ({ value }) => { setProgress(value); });

      // ── Shadow mask ──────────────────────────────────────────
      const shadows = pane.addFolder({ title: 'Shadow Mask', expanded: false });

      const sState = {
        threshold: uShadowThreshold.value as number,
        softness: uShadowSoftness.value as number,
        alpha: uShadowAlpha.value as number,
      };

      shadows.addBinding(sState, 'threshold', { min: 0, max: 1, step: 0.01, label: 'Threshold' })
        .on('change', ({ value }) => { uShadowThreshold.value = value; });

      shadows.addBinding(sState, 'softness', { min: 0, max: 1, step: 0.01, label: 'Softness' })
        .on('change', ({ value }) => { uShadowSoftness.value = value; });

      shadows.addBinding(sState, 'alpha', { min: 0, max: 1, step: 0.01, label: 'Opacity' })
        .on('change', ({ value }) => { uShadowAlpha.value = value; });

      // ── Gradient ─────────────────────────────────────────
      const gradient = pane.addFolder({ title: 'Gradient', expanded: false });

      const gState = {
        width: uGradientWidth.value as number,
      };

      gradient.addBinding(gState, 'width', { min: 0.5, max: 4, step: 0.1, label: 'Width' })
        .on('change', ({ value }) => { uGradientWidth.value = value; });
    </script>
  </body>
</html>

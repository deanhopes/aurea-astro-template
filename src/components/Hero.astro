---
import { Image } from 'astro:assets';

import heroImage from '../assets/images/hero-aerial-bay.jpg';
---

<section class="hero" id="hero" data-hero>
  <div class="hero__image">
    <Image
      src={heroImage}
      alt="Aerial view of Miami Beach coastline and Biscayne Bay"
      widths={[768, 1280, 1920, 2560]}
      sizes="100vw"
      loading="eager"
    />
  </div>
  <div class="hero__content" data-reveal>
    <p class="hero__label">Edgewater, Miami</p>
    <h1 class="hero__headline">A private waterfront tower, set to the rhythm of the bay.</h1>
  </div>
</section>

---
/**
 * Hero — full-viewport image with bottom-centre text overlay.
 * 4px radius, clipped. Placeholder gradient until real render is dropped in.
 */
import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero.png';
---

<section class="hero" data-hero>
  <div class="hero__image">
    <video
      src="/video/hero.mp4"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster={heroImage.src}
      aria-label="Aurea Residences waterfront tower at golden hour"></video>
  </div>
  <div class="hero__content" data-reveal>
    <p class="hero__label">Edgewater, Miami</p>
    <h1 class="hero__headline">A private waterfront tower, set to the rhythm of the bay.</h1>
  </div>
</section>

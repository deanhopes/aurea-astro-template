---
/**
 * FooterHaze — canvas-rendered concentric sunset gradients.
 * Scroll-driven reveal synced to the footer trigger.
 */
---

<canvas class="footer-haze" aria-hidden="true" data-footer-haze></canvas>

<style>
  .footer-haze {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
</style>

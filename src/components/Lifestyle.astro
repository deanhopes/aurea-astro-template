---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const slides = (await getCollection('lifestyle')).sort((a, b) => a.data.order - b.data.order);
---

<section class="lifestyle" id="lifestyle" data-reveal>
  <div class="lifestyle__header">
    <div class="lifestyle__header-left">
      <p class="lifestyle__label">The Lifestyle</p>
      <h2 class="text-section-heading">
        Aurea Residences includes a full wellness floor, rooftop pool, and private spa.
      </h2>
    </div>
  </div>

  <div class="lifestyle__slider">
    <div class="lifestyle__slider-container">
      <div class="lifestyle__track">
        {
          slides.map(({ data: slide }) => (
            <div class="lifestyle__slide">
              <Image src={slide.image} alt={slide.alt} loading="lazy" decoding="async" />
              <div class="lifestyle__slide-overlay" />
              <span class="lifestyle__slide-caption lifestyle__slide-caption--top">
                {slide.top}
              </span>
              <span class="lifestyle__slide-caption lifestyle__slide-caption--bottom">
                {slide.bottom}
              </span>
            </div>
          ))
        }
      </div>
      <div class="lifestyle__marker"></div>
    </div>
  </div>

  <div class="lifestyle__footer">
    <div class="lifestyle__copy">
      <p>
        Aurea offers a cold plunge, infrared sauna, and rooftop lap pool within the building. Each
        wellness space is available exclusively to residents — no booking windows, no queues, no
        strangers. The bay beneath it sets the temperature.
      </p>
      <p>
        The wellness floor runs from cold plunge to breathwork terrace. The spa is staffed by
        therapists who know your name. The residents' lounge keeps one item on the schedule: sunset.
        A building that returns the day to you, hour by hour.
      </p>
      <a href="#lifestyle" class="btn btn--ghost lifestyle__cta">Step Inside the Lifestyle</a>
    </div>
  </div>
</section>

---
/**
 * Lifestyle — editorial section with draggable image slider.
 * Horizontal drag strip of lifestyle/amenity images, copy block below.
 */

const slides = [
  { image: '/images/lifestyle-neighbourhood.jpg', alt: 'Couple walking along the bay at golden hour, Edgewater neighbourhood' },
  { image: '/images/lifestyle-yoga.jpg', alt: 'Morning yoga on a wooden terrace, aerial view' },
  { image: '/images/lifestyle-plunge.jpg', alt: 'Cold plunge pool in warm ambient light' },
  { image: '/images/lifestyle-04.jpg', alt: 'Infrared sauna with floor-to-ceiling glass overlooking the bay' },
  { image: '/images/lifestyle-05.jpg', alt: 'Rooftop pool deck at sunset with lounge seating' },
  { image: '/images/lifestyle-06.jpg', alt: 'Breathwork terrace surrounded by tropical planting' },
  { image: '/images/lifestyle-07.jpg', alt: 'Spa treatment room with natural stone and soft lighting' },
  { image: '/images/lifestyle-08.jpg', alt: 'Residents lounge with curated art and bay views' },
];
---

<section class="lifestyle" data-reveal>
  <p class="lifestyle__label">The Lifestyle</p>
  <h2 class="lifestyle__heading">A sanctuary calibrated to your body</h2>

  <div class="lifestyle__grid">
    <div class="lifestyle__slider">
      <div class="lifestyle__track">
        {slides.map((slide) => (
          <div class="lifestyle__slide">
            <img src={slide.image} alt={slide.alt} loading="lazy" />
          </div>
        ))}
      </div>
      <div class="lifestyle__marker"></div>
    </div>

    <div class="lifestyle__copy">
      <p>
        A cold plunge at dawn to reset your cortisol. Infrared before the
        sun is up. Laps in water that holds the same temperature as the bay
        beneath it. Every space shaped around what your body actually needs,
        at the hour it needs it.
      </p>
      <p>
        The wellness floor. The breathwork terrace. Cold and warm circuits
        that follow the rhythm of the morning. A sanctuary by the sea where
        switching off is the entire point.
      </p>
      <a href="/lifestyle" class="lifestyle__cta">Explore the Lifestyle</a>
    </div>
  </div>

  <div class="lifestyle__pair">
    <div class="lifestyle__pair-image">
      <img src="/images/lifestyle-yoga.jpg" alt="Morning yoga on a wooden terrace, aerial view" loading="lazy" data-parallax />
    </div>
    <div class="lifestyle__pair-image">
      <img src="/images/lifestyle-plunge.jpg" alt="Cold plunge pool in warm ambient light" loading="lazy" data-parallax />
    </div>
  </div>
</section>

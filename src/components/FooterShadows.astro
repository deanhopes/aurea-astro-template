---
/**
 * FooterShadows — WebGPU canvas for video shadow silhouettes + lighting.
 * Height-field water surface model with fBm-driven caustics, refraction,
 * and directional lighting. See src/lib/footer-shaders.ts for the model.
 */
---

<video
  class="footer-shadows__video"
  data-footer-shadows-video
  muted
  loop
  playsinline
  preload="none"
  aria-hidden="true"
>
  <source src="/video/leaf-shadows.webm" type="video/webm" />
  <source src="/video/leaf-shadows.mp4" type="video/mp4" />
</video>

<canvas class="footer-shadows" aria-hidden="true" data-footer-shadows></canvas>

<!-- Brand-tint overlay: opaque parchment at top → 20% alpha at bottom.
     Anchors the footer back to brand at the top while letting the caustic
     effect read at the bottom. -->
<div class="footer-shadows__overlay" aria-hidden="true"></div>

<style>
  .footer-shadows__video {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
    z-index: -1;
  }

  .footer-shadows {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .footer-shadows__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      var(--color-background) 0%,
      color-mix(in srgb, var(--color-background) 20%, transparent) 100%
    );
  }
</style>

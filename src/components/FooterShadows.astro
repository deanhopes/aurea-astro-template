---
/**
 * FooterShadows — WebGPU canvas for video shadow silhouettes.
 * Luminance-threshold shader maps palm leaf video to warm palette.
 * Single opaque canvas — is the footer background (no blend mode).
 */
---

<video
  class="footer-shadows__video"
  data-footer-shadows-video
  muted
  loop
  playsinline
  preload="none"
  aria-hidden="true"
>
  <source src="/video/leaf-shadows.webm" type="video/webm" />
  <source src="/video/leaf-shadows.mp4" type="video/mp4" />
</video>

<canvas class="footer-shadows" aria-hidden="true" data-footer-shadows></canvas>

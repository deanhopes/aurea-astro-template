---
/**
 * FooterShadows — WebGL canvas for video shadow silhouettes.
 * Luminance-threshold shader maps palm leaf video to warm palette.
 * Composites over the haze canvas via CSS stacking + multiply blend.
 */
---

<video
  class="footer-shadows__video"
  data-footer-shadows-video
  muted
  loop
  playsinline
  preload="none"
  aria-hidden="true"
>
  <source src="/video/leaf-shadows.webm" type="video/webm" />
  <source src="/video/leaf-shadows.mp4" type="video/mp4" />
</video>

<canvas
  class="footer-shadows"
  aria-hidden="true"
  data-footer-shadows
></canvas>

<style>
  .footer-shadows__video {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
    z-index: -1;
  }

  .footer-shadows {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    mix-blend-mode: multiply;
  }
</style>

---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const residences = (await getCollection('residences')).sort((a, b) => a.data.order - b.data.order);
---

<section class="residences" id="residences" data-reveal>
  <p class="residences__label">The Residences</p>
  <h2 class="residences__heading text-section-heading">Three ways to wake up<br />on the water.</h2>

  <div class="residences__grid">
    {
      residences.map(({ data: r }) => (
        <a href="#residences" class="residences__card">
          <div class="residences__card-image">
            <Image src={r.image} alt={r.alt} loading="lazy" decoding="async" />
          </div>
          <div class="residences__card-info">
            <h3 class="residences__card-name">{r.name}</h3>
            <p class="residences__card-detail">{r.detail}</p>
            <dl class="residences__card-specs">
              {r.specs.map((s) => (
                <div class="residences__spec">
                  <dt class="residences__spec-label">{s.label}</dt>
                  <dd class="residences__spec-value">{s.value}</dd>
                </div>
              ))}
            </dl>
          </div>
        </a>
      ))
    }
  </div>

  <div class="residences__footer">
    <a href="#residences" class="btn btn--primary">See Every Residence</a>
  </div>
</section>

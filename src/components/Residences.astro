---
/**
 * Residences — three-card editorial teaser.
 */
const residences = [
  {
    name: 'Three Bedroom',
    detail: 'Bay view east. The water changes colour six times before breakfast.',
    image: '/images/vision-interior.jpg',
    alt: 'Three bedroom residence interior with bay view',
    specs: [
      { label: 'Beds', value: '3 / 3.5' },
      { label: 'Area', value: '1,800–2,100 sq ft' },
      { label: 'Aspect', value: 'East' },
    ],
  },
  {
    name: 'Four Bedroom',
    detail: 'Corner aspect. The sun crosses the flat from one terrace to the other.',
    image: '/images/vision-tower.jpg',
    alt: 'Four bedroom residence with wraparound terrace',
    specs: [
      { label: 'Beds', value: '4 / 4.5' },
      { label: 'Area', value: '2,400–3,100 sq ft' },
      { label: 'Aspect', value: 'Corner' },
    ],
  },
  {
    name: 'Penthouse',
    detail: 'Top floor, private lift. Windows on every side of the bay.',
    image: '/images/vision-sunset.jpg',
    alt: 'Penthouse terrace at sunset overlooking the bay',
    specs: [
      { label: 'Beds', value: '5 / 6.5' },
      { label: 'Area', value: '4,200+ sq ft' },
      { label: 'Aspect', value: 'Full floor' },
    ],
  },
];
---

<section class="residences" data-reveal>
  <p class="residences__label">The Residences</p>
  <h2 class="residences__heading">Three ways to live on the bay</h2>

  <div class="residences__grid">
    {
      residences.map((r) => (
        <a href="/residences" class="residences__card">
          <div class="residences__card-image">
            <img src={r.image} alt={r.alt} loading="lazy" decoding="async" />
          </div>
          <div class="residences__card-info">
            <h3 class="residences__card-name">{r.name}</h3>
            <p class="residences__card-detail">{r.detail}</p>
            <dl class="residences__card-specs">
              {r.specs.map((s) => (
                <div class="residences__spec">
                  <dt class="residences__spec-label">{s.label}</dt>
                  <dd class="residences__spec-value">{s.value}</dd>
                </div>
              ))}
            </dl>
          </div>
        </a>
      ))
    }
  </div>

  <div class="residences__footer">
    <a href="/residences" class="btn btn--primary">View All Floor Plans</a>
  </div>
</section>

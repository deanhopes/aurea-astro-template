---
/**
 * Residences — three-card grid teaser.
 * Blocked-in layout; styling comes later.
 */
import { Bed, Maximize, Compass, Waves } from '@lucide/astro';

const residences = [
  {
    name: 'Three Bedroom',
    detail: 'East-facing. First light on the water before the city wakes up.',
    image: '/images/vision-interior.jpg',
    alt: 'Three bedroom residence interior with bay view',
    specs: [
      { icon: 'bed', label: '3 Bed · 3.5 Bath' },
      { icon: 'maximize', label: '1,800 – 2,100 sq ft' },
      { icon: 'compass', label: 'East-facing aspect' },
    ],
  },
  {
    name: 'Four Bedroom',
    detail: 'Corner wrap. Terrace for twelve. Sunset and sunrise from the same home.',
    image: '/images/vision-tower.jpg',
    alt: 'Four bedroom residence with wraparound terrace',
    specs: [
      { icon: 'bed', label: '4 Bed · 4.5 Bath' },
      { icon: 'maximize', label: '2,400 – 3,100 sq ft' },
      { icon: 'compass', label: 'Corner aspect' },
    ],
  },
  {
    name: 'Penthouse',
    detail: 'Full floor. Private lift. The whole horizon is yours.',
    image: '/images/vision-sunset.jpg',
    alt: 'Penthouse terrace at sunset overlooking the bay',
    specs: [
      { icon: 'bed', label: '5 Bed · 6.5 Bath' },
      { icon: 'maximize', label: '4,200+ sq ft' },
      { icon: 'waves', label: 'Full-floor panorama' },
    ],
  },
];

const icons = { bed: Bed, maximize: Maximize, compass: Compass, waves: Waves };
---

<section class="residences" data-reveal>
  <p class="residences__label">The Residences</p>
  <h2 class="residences__heading">Three ways to live on the bay</h2>

  <div class="residences__grid">
    {residences.map((r) => (
      <a href="/residences" class="residences__card">
        <div class="residences__card-image">
          <img src={r.image} alt={r.alt} loading="lazy" decoding="async" />
        </div>
        <div class="residences__card-info">
          <h3 class="residences__card-name">{r.name}</h3>
          <p class="residences__card-detail">{r.detail}</p>
          <ul class="residences__card-specs">
            {r.specs.map((s) => {
              const Icon = icons[s.icon as keyof typeof icons];
              return (
                <li class="residences__spec">
                  <Icon size={16} stroke-width={1.5} />
                  <span>{s.label}</span>
                </li>
              );
            })}
          </ul>
        </div>
      </a>
    ))}
  </div>

  <div class="residences__footer">
    <a href="/residences" class="residences__cta">View All Floor Plans</a>
  </div>
</section>

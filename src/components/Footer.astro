---
import FooterShadows from '@components/FooterShadows.astro';
import { footerLinkGroups, contact } from '@data/site';
---

<footer class="site-footer" data-footer>
  <div class="site-footer__inner">
    <FooterShadows />

    <div class="site-footer__content">
      <!-- Contact -->
      <address class="site-footer__contact">
        <span class="site-footer__contact-name">{contact.address.name}</span>
        <span>{contact.address.street}</span>
        <span>{contact.address.city}</span>
        <a href={contact.phone.href} class="site-footer__contact-link">{contact.phone.display}</a>
        <a
          href={contact.mapUrl}
          class="site-footer__contact-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          View on Map
        </a>
      </address>

      <!-- Navigation -->
      <div class="site-footer__nav">
        {
          footerLinkGroups.map((group) => (
            <ul class="site-footer__links">
              {group.map(({ label, href }) => (
                <li>
                  <a href={href} class="site-footer__link">
                    {label}
                  </a>
                </li>
              ))}
            </ul>
          ))
        }
      </div>
    </div>
  </div>
</footer>

---
/**
 * Footer — fixed behind content, revealed as page scrolls past.
 * Large AUREA wordmark, decorative wave stroke, icon, tagline, nav links.
 */
import FooterHaze from '@components/FooterHaze.astro';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

const iconSvg = readFileSync(resolve('public/images/aurea-icon.svg'), 'utf-8');

const linkGroups = [
  [
    { label: 'Vision', href: '/vision' },
    { label: 'Residences', href: '/residences' },
    { label: 'Lifestyle', href: '/lifestyle' },
    { label: 'Neighbourhood', href: '/neighbourhood' },
  ],
  [
    { label: 'Location', href: '/location' },
    { label: 'The Team', href: '/team' },
    { label: 'Blog', href: '/blog' },
  ],
  [
    { label: 'Terms & Conditions', href: '/terms' },
    { label: 'Privacy Policy', href: '/privacy' },
  ],
];
---

<footer class="site-footer" data-footer>
  <div class="site-footer__inner">
    <FooterHaze />

    <div class="site-footer__content">
      <!-- Icon — inlined SVG for draw-in animation -->
      <div class="site-footer__icon" data-footer-icon>
        <Fragment set:html={iconSvg} />
      </div>

      <!-- Tagline row -->
      <div class="site-footer__tagline-row">
        <p class="site-footer__flank">Edgewater</p>
        <p class="site-footer__tagline">
          A waterfront home on Biscayne Bay
        </p>
        <p class="site-footer__flank">Miami</p>
      </div>

      <!-- Navigation -->
      <div class="site-footer__nav">
        {linkGroups.map((group) => (
          <ul class="site-footer__links">
            {group.map(({ label, href }) => (
              <li>
                <a href={href} class="site-footer__link">{label}</a>
              </li>
            ))}
          </ul>
        ))}
      </div>
    </div>

    <!-- Giant wordmark -->
    <p class="site-footer__wordmark" aria-hidden="true">AUREA</p>
  </div>
</footer>

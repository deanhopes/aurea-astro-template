---
/**
 * Footer — fixed behind content, revealed as page scrolls past.
 * Large AUREA wordmark, decorative wave stroke, icon, tagline, nav links.
 */

const linkGroups = [
  [
    { label: 'Vision', href: '/vision' },
    { label: 'Residences', href: '/residences' },
    { label: 'Lifestyle', href: '/lifestyle' },
    { label: 'Neighbourhood', href: '/neighbourhood' },
  ],
  [
    { label: 'Location', href: '/location' },
    { label: 'The Team', href: '/team' },
    { label: 'Blog', href: '/blog' },
  ],
  [
    { label: 'Terms & Conditions', href: '/terms' },
    { label: 'Privacy Policy', href: '/privacy' },
    { label: 'Enquire', href: '#enquire' },
  ],
];
---

<footer class="site-footer" data-footer>
  <div class="site-footer__inner">
    <!-- Atmospheric haze -->
    <svg class="site-footer__haze" aria-hidden="true" viewBox="0 0 1440 900" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <filter id="haze-blur" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur in="SourceGraphic" stdDeviation="120" />
        </filter>
      </defs>
      <g filter="url(#haze-blur)">
        <!-- Warm coral sweep -->
        <ellipse cx="900" cy="350" rx="600" ry="200" fill="var(--color-coral)" opacity="0.08" transform="rotate(-15 900 350)" />
        <!-- Golden peach glow -->
        <ellipse cx="500" cy="500" rx="500" ry="250" fill="var(--color-golden-peach)" opacity="0.12" transform="rotate(-8 500 500)" />
        <!-- Subtle bronze accent -->
        <ellipse cx="1100" cy="600" rx="350" ry="180" fill="var(--color-aurea-bronze)" opacity="0.06" transform="rotate(10 1100 600)" />
      </g>
    </svg>

    <!-- Icon -->
    <img
      src="/images/aurea-icon.svg"
      alt="Aurea Residences"
      class="site-footer__icon"
    />

    <!-- Tagline row -->
    <div class="site-footer__tagline-row">
      <p class="site-footer__flank">Edgewater</p>
      <p class="site-footer__tagline">
        A waterfront home on Biscayne Bay
      </p>
      <p class="site-footer__flank">Miami</p>
    </div>

    <!-- Navigation -->
    <div class="site-footer__nav">
      {linkGroups.map((group) => (
        <ul class="site-footer__links">
          {group.map(({ label, href }) => (
            <li>
              <a href={href} class="site-footer__link">{label}</a>
            </li>
          ))}
        </ul>
      ))}
    </div>

    <!-- Giant wordmark -->
    <p class="site-footer__wordmark" aria-hidden="true">AUREA</p>
  </div>
</footer>

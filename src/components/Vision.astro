---
import { Image } from 'astro:assets';
import { getEntry } from 'astro:content';

const vision = await getEntry('pages', 'vision');
if (!vision) throw new Error('Missing content: pages/vision.yaml');
const { label, towerBody, cardCopy, cta, images, captions } = vision.data;
---

<section class="vision" id="vision" data-vision>
  <div class="vision__sticky">
    <div class="vision__track" data-vision-track>
      <!-- Panel 1: The Vision + The Tower text -->
      <div class="vision__panel vision__panel--intro">
        <p class="vision__label">{label}</p>
        <div class="vision__tower">
          <p class="vision__tower-body">{towerBody}</p>
        </div>
      </div>

      <!-- Panel 2: Editorial card -->
      <div class="vision__panel vision__panel--card">
        <div class="vision__card">
          <!-- Left: large image + numbered caption -->
          <div class="vision__card-left">
            <div class="vision__card-image vision__card-image--tower">
              <Image
                src={images.tower.src}
                alt={images.tower.alt}
                widths={[400, 600, 800]}
                sizes="(max-width: 1024px) 90vw, 35vw"
                format="webp"
                quality={80}
                loading="lazy"
                decoding="async"
              />
            </div>
            <p class="vision__caption vision__caption--number">{captions.towerNumber}</p>
          </div>

          <!-- Centre: copy + secondary image -->
          <div class="vision__card-centre">
            <div class="vision__card-copy">
              {cardCopy.map((paragraph) => <p>{paragraph}</p>)}
              <a href={cta.href} class="vision__cta">{cta.label}</a>
            </div>
          </div>

          <!-- Right: small image + caption -->
          <div class="vision__card-right">
            <div class="vision__card-image vision__card-image--interior">
              <Image
                src={images.interior.src}
                alt={images.interior.alt}
                widths={[400, 600, 800]}
                sizes="(max-width: 1024px) 90vw, 25vw"
                format="webp"
                quality={80}
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="vision__caption-group">
              <p class="vision__caption vision__caption--muted">{captions.interiorMuted}</p>
              <p class="vision__caption">{captions.interiorNumber}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Panel 3: Full-bleed entrance image + drone video -->
      <div class="vision__panel vision__panel--images">
        <div class="vision__image-pair">
          <div class="vision__card-image vision__card-image--entrance">
            <Image
              src={images.entrance.src}
              alt={images.entrance.alt}
              widths={[400, 600, 800]}
              sizes="(max-width: 1024px) 90vw, 45vw"
              format="webp"
              quality={80}
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="vision__card-image vision__card-image--video">
            <video
              src={images.video.src}
              aria-label={images.video.alt}
              autoplay
              muted
              loop
              playsinline
              preload="metadata"></video>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

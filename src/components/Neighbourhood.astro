---
/**
 * Neighbourhood — tabbed section.
 * Tabs across the top, 12-col grid below: image left, map top-right, body copy + CTA right.
 * Mobile: accordion with inline image + text per item.
 * Content from the `neighbourhood` collection — edit src/content/neighbourhood/*.yaml.
 */
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const entries = await getCollection('neighbourhood');
const items = entries
  .slice()
  .sort((a, b) => a.data.order - b.data.order)
  .map((entry) => ({ id: entry.id, ...entry.data }));
---

<section class="neighbourhood" data-neighbourhood>
  <div class="neighbourhood__container">
    <div class="neighbourhood__intro">
      <div class="neighbourhood__intro-head">
        <p class="neighbourhood__label">The Neighbourhood</p>
        <h2 class="neighbourhood__heading">A neighbourhood you walk into,<br />not out of.</h2>
      </div>
    </div>

    <!-- Desktop tabs -->
    <div class="neighbourhood__tabs" role="tablist">
      {
        items.map((item, i) => (
          <button
            class:list={['neighbourhood__tab', { 'is-active': i === 0 }]}
            role="tab"
            type="button"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-${item.id}`}
            data-neighbourhood-tab={item.id}
            data-layout={item.layout}
          >
            {item.label}
          </button>
        ))
      }
      <div class="neighbourhood__indicator" data-neighbourhood-indicator></div>
    </div>

    <!-- Desktop content grid -->
    <div class="neighbourhood__content" role="tabpanel" data-layout="a">
      <div class="neighbourhood__media">
        {
          items.map((item, i) => (
            <div
              class:list={['neighbourhood__image', { 'is-active': i === 0 }]}
              data-neighbourhood-image={item.id}
            >
              <Image
                src={item.image}
                alt={item.alt}
                widths={[400, 600, 800]}
                sizes="(max-width: 767px) 100vw, (max-width: 1023px) 45vw, 35vw"
                format="webp"
                quality={80}
                loading="lazy"
              />
            </div>
          ))
        }
      </div>

      <div class="neighbourhood__text">
        {
          items.map((item, i) => (
            <div
              class:list={['neighbourhood__text-panel', { 'is-active': i === 0 }]}
              data-neighbourhood-text={item.id}
            >
              {item.description ? (
                <>
                  <p class="neighbourhood__body">{item.description}</p>
                  <a href="/neighbourhood" class="neighbourhood__cta">
                    Walk the Neighbourhood
                  </a>
                </>
              ) : null}
            </div>
          ))
        }
      </div>

      <div class="neighbourhood__map">
        {
          items.map((item, i) => (
            <div
              class:list={['neighbourhood__map-panel', { 'is-active': i === 0 }]}
              data-neighbourhood-map={item.id}
            >
              <iframe
                data-src={item.mapEmbed}
                title={`Map of ${item.label}`}
                loading="lazy"
                allowfullscreen=""
              />
            </div>
          ))
        }
      </div>
    </div>

    <!-- Mobile accordion -->
    <div class="neighbourhood__accordion">
      {
        items.map((item, i) => (
          <div
            class:list={['neighbourhood__item', { 'is-active': i === 0 }]}
            data-neighbourhood-item={item.id}
          >
            <button class="neighbourhood__line" type="button">
              <span class="neighbourhood__line-text">{item.label}</span>
              <svg
                class="neighbourhood__line-chevron"
                width="20"
                height="20"
                viewBox="0 0 20 20"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M5 7.5L10 12.5L15 7.5"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </button>
            <div class="neighbourhood__inline-content" data-neighbourhood-inline={item.id}>
              <div class="neighbourhood__inline-image">
                <Image
                  src={item.image}
                  alt={item.alt}
                  widths={[400, 600]}
                  sizes="(max-width: 767px) 95vw"
                  format="webp"
                  quality={80}
                  loading="lazy"
                />
              </div>
              <p class="neighbourhood__inline-body">{item.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

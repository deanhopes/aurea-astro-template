---
/**
 * Neighbourhood — editorial scattered layout.
 * Label + copy top-left, three asymmetric images, distance list + CTA bottom-right.
 */
---

<section class="neighbourhood">
  <div class="neighbourhood__column">
    <div class="neighbourhood__text">
      <p class="neighbourhood__label">The Neighbourhood</p>
      <p class="neighbourhood__body">
        Five minutes from Wynwood's galleries, ten from the Design District,
        fifteen from the sand. But the reason people stay is the bay. Morning
        light that turns the water from navy to teal to gold in the time it
        takes to finish a coffee.
      </p>
    </div>

    <div class="neighbourhood__info">
      <ul class="neighbourhood__distances">
        <li>Wynwood, 5 min</li>
        <li>Design District, 10 min</li>
        <li>Downtown Miami, 10 min</li>
        <li>Miami Beach, 15 min</li>
      </ul>
      <a href="/neighbourhood" class="neighbourhood__cta">
        Discover the Neighbourhood
      </a>
    </div>
  </div>

  <div class="neighbourhood__image neighbourhood__image--palms">
    <img src="/images/neighbourhood-palms.jpg" alt="Palm trees framed by building overhangs, looking up at blue sky" loading="lazy" />
  </div>

  <div class="neighbourhood__image neighbourhood__image--sunset">
    <img src="/images/neighbourhood-sunset.jpg" alt="Palm tree silhouettes against a pink and orange sunset" loading="lazy" />
  </div>

  <div class="neighbourhood__image neighbourhood__image--pool">
    <img src="/images/neighbourhood-pool.jpg" alt="Poolside cabanas with tropical greenery" loading="lazy" />
  </div>
</section>

---
import { ClientRouter } from 'astro:transitions';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import SEO from '@components/seo/Head.astro';
import '@styles/fonts.css';
import '@styles/global.css';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Aurea Residences — Waterfront living in Edgewater, Miami' } =
  Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Booting flag pins curtain over viewport until TSL compile finishes (~1500ms) -->
    <script is:inline>
      document.documentElement.dataset.booting = '';
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="preload"
      href="/fonts/TestSohne-Leicht.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/AktivGrotesk-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="preconnect" href="https://www.google.com" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <SEO title={title} description={description} />
    <slot name="head" />
    <ClientRouter />

    <!-- Early Lenis — closes the "scroll feels locked on reload" gap before astro:page-load fires -->
    <script>
      import { initLenis } from '@lib/lenis';
      initLenis();
    </script>
  </head>
  <body>
    <!-- Lenis scrollend workaround (known Astro ClientRouter conflict) -->
    <script is:inline>
      delete window.onscrollend;
    </script>

    <div id="page-curtain" transition:persist aria-hidden="true">
      <div class="curtain__panel curtain__panel--left"></div>
      <div class="curtain__panel curtain__panel--right"></div>
    </div>

    <Nav />
    <main id="main-content">
      <slot />
      <!-- Invisible trigger for footer wordmark animation -->
      <div
        data-footer-trigger
        aria-hidden="true"
        style="position:relative;height:1px;pointer-events:none;"
      >
      </div>
    </main>
    <Footer />

    <!-- Single bootstrap entry. Heavy modules lazy-loaded inside (idle + IO gated) -->
    <script>
      import { bootstrap } from '@lib/bootstrap';
      bootstrap();
    </script>
  </body>
</html>

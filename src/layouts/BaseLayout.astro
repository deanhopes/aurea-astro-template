---
import { ClientRouter } from 'astro:transitions';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import SEO from '@components/seo/Head.astro';
import '@styles/fonts.css';
import '@styles/global.css';

export interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Aurea Residences — Waterfront living in Edgewater, Miami',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <SEO title={title} description={description} />
    <slot name="head" />
    <ClientRouter />
  </head>
  <body>
    <!-- Lenis scrollend workaround (known Astro ClientRouter conflict) -->
    <script is:inline>delete window.onscrollend;</script>

    <Nav />
    <main id="main-content">
      <slot />
      <!-- Invisible trigger for footer wordmark animation -->
      <div data-footer-trigger aria-hidden="true" style="position:relative;height:1px;pointer-events:none;"></div>
    </main>
    <Footer />

    <!-- Lenis smooth scroll -->
    <script>
      import { initLenis, destroyLenis } from '@lib/lenis';

      document.addEventListener('astro:page-load', initLenis);
      document.addEventListener('astro:before-swap', destroyLenis);
    </script>

    <!-- Nav menu toggle -->
    <script>
      import { initNav, destroyNav } from '@lib/nav';

      document.addEventListener('astro:page-load', initNav);
      document.addEventListener('astro:before-swap', destroyNav);
    </script>

    <!-- GSAP context lifecycle -->
    <script>
      import { initAnimations, cleanupAnimations } from '@lib/animations';

      document.addEventListener('astro:page-load', initAnimations);
      document.addEventListener('astro:after-swap', cleanupAnimations);
    </script>

    <!-- Footer haze canvas -->
    <script>
      import { initFooterHaze, destroyFooterHaze } from '@lib/footer-haze';

      document.addEventListener('astro:page-load', initFooterHaze);
      document.addEventListener('astro:before-swap', destroyFooterHaze);
    </script>

    <!-- Neighbourhood cursor inertia -->
    <script>
      import { initNeighbourhoodInertia, destroyNeighbourhoodInertia } from '@lib/neighbourhood-inertia';

      document.addEventListener('astro:page-load', initNeighbourhoodInertia);
      document.addEventListener('astro:before-swap', destroyNeighbourhoodInertia);
    </script>

    <!-- Scroll reveal observer -->
    <script>
      function initReveal() {
        const elements = document.querySelectorAll('[data-reveal]');
        if (!elements.length) return;

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
        );

        elements.forEach((el) => observer.observe(el));
      }

      document.addEventListener('astro:page-load', initReveal);
    </script>
  </body>
</html>
